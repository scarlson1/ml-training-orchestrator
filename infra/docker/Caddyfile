{
    # Let's Encrypt sends expiry warnings here (optional but good practice)
    email {$CADDY_EMAIL}
}

# MLFLOW_DOMAIN is injected from .env — e.g. mlflow.150-136-1-2.sslip.io
# sslip.io wildcard DNS resolves any subdomain to the same IP.
{$MLFLOW_DOMAIN} {
    basicauth {
        {$MLFLOW_USER} {$MLFLOW_HASHED_PASSWORD}
    }

    reverse_proxy mlflow:5000

    encode gzip

    log {
        output stderr
        format console
    }
}

# DAGSTER_DOMAIN is injected from .env — e.g. dagster.150-136-1-2.sslip.io
{$DAGSTER_DOMAIN} {
    basicauth {
        {$DAGSTER_USER} {$DAGSTER_HASHED_PASSWORD}
    }

    reverse_proxy dagster:3000

    encode gzip

    log {
        output stderr
        format console
    }
}

# SERVING_DOMAIN is injected from .env — e.g. 150-136-1-2.sslip.io or bmo-api.duckdns.org
# Caddy automatically obtains and renews a Let's Encrypt cert for this domain.
{$SERVING_DOMAIN} {
    reverse_proxy serving:8080

    encode gzip

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options  "nosniff"
        X-Frame-Options         "DENY"
    }

    log {
        output stderr
        format console
    }

    # When the upstream serving container is down, Caddy returns a 503 from its
    # own error handler — which has none of FastAPI's CORS headers. The browser
    # then reports a misleading CORS error instead of the real 503. Adding these
    # headers here ensures the actual status code is visible in the browser.
    handle_errors {
        header Access-Control-Allow-Origin "https://ml-training-orchestrator.vercel.app"
        header Access-Control-Allow-Methods "GET, POST, OPTIONS"
        header Access-Control-Allow-Headers "Content-Type, Authorization"
        respond "{http.error.status_code} {http.error.status_text}"
    }
}
