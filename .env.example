DAGSTER_HOME=~/.dagster/bmo

# Object store
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=admin
S3_SECRET_ACCESS_KEY=password123
S3_BUCKET_RAW=raw
S3_BUCKET_STAGING=staging
S3_BUCKET_REJECTED=rejected

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# Postgres (Dagster + MLflow metadata)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bmo
POSTGRES_USER=bmo
POSTGRES_PASSWORD=bmo

# Redis (Feast online store)
REDIS_URL=redis://localhost:6379
