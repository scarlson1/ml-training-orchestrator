DAGSTER_HOME=~/.dagster/bmo

# Object store - MinIO (dev) / Cloudflare R2 (deployed)
S3_ENDPOINT_URL=http://localhost:9000
# Feast / Object store (feast/boto3 automatically pick up AWS_* env vars)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:9000
# for dbt profiles.yml (mirror AWS_* above) TODO: switch vars to AWS_* ??
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# Feast registry — S3 path shared between Dagster (writes) and serving (reads)
# Local dev: SQLite file (fast, no cloud needed). Prod: s3://bmo-staging/feast/registry.db
FEAST_REGISTRY_PATH=data/registry.db

# Buckets
S3_BUCKET_RAW=raw
S3_BUCKET_STAGING=staging
S3_BUCKET_REJECTED=rejected
FEAST_S3_BASE=s3://staging/feast
DATASET_S3_BASE=s3://staging/datasets

# Redis (Feast online store)
REDIS_URL=redis://localhost:6379

# dbt / DuckDB
# DuckDB's S3 endpoint omits the http:// scheme — it only accepts host:port
# only required for dbt profiles.yml (otherwise could stick to pydantic property to strip protocol from AWS_ENDPOINT_URL)
DUCKDB_S3_ENDPOINT=localhost:9000
# Path for the ephemeral DuckDB database file used during dbt runs
DUCKDB_PATH=/tmp/bmo_features.duckdb

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# Postgres (Dagster + MLflow metadata)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bmo
POSTGRES_USER=bmo
POSTGRES_PASSWORD=bmo

# Iceberg - optional: pydantic derives from POSTGRES_* env vars
ICEBERG_CATALOG_URI=postgresql+psycopg2://bmo:bmo@localhost:5432/iceberg

ADMIN_TOKEN=change-me-in-production    # Bearer token for /admin/reload
SHADOW_MODEL_VERSION=1                 # optional: e.g. '5' to run shadow deploy
FEATURE_REPO_DIR=feature_repo/
MODEL_NAME=bmo_flight_delay


# ----- DEPLOYED ONLY ----- #
# Deployment only - Caddy
SERVING_DOMAIN=<DEPLOYMENT_IP>.sslip.io
CADDY_EMAIL=<YOUR_EMAIL>@icloud.com

# Serving image — GHCR_OWNER is your GitHub username (github.com/<owner>)
GHCR_OWNER=${{ github.repository_owner }}
