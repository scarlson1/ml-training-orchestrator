DAGSTER_HOME=~/.dagster/bmo

# Object store
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET_RAW=raw
S3_BUCKET_STAGING=staging
S3_BUCKET_REJECTED=rejected
# Feast / Object store (feast/boto3 automatically pick up AWS_* env vars)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:9000
FEAST_S3_BASE=s3://staging/feast
DATASET_S3_BASE=s3://staging/datasets

# for dbt profiles.yml (mirror AWS_* above)
# TODO: switch vars to AWS_* ??
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# dbt / DuckDB
# DuckDB's S3 endpoint omits the http:// scheme — it only accepts host:port
# only required for dbt profiles.yml (otherwise could stick to pydantic property to strip protocol from AWS_ENDPOINT_URL)
DUCKDB_S3_ENDPOINT=localhost:9000
# Path for the ephemeral DuckDB database file used during dbt runs
DUCKDB_PATH=/tmp/bmo_features.duckdb

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# Postgres (Dagster + MLflow metadata)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bmo
POSTGRES_USER=bmo
POSTGRES_PASSWORD=bmo

# Redis (Feast online store)
REDIS_URL=redis://localhost:6379

# Iceberg
# optional - pydantic derives from POSTGRES_* env vars
ICEBERG_CATALOG_URI=postgresql+psycopg2://bmo:bmo@localhost:5432/iceberg
# ICEBERG_CATALOG_URI=sqlite:////Users/<you>/.dagster/bmo_iceberg.db

ADMIN_TOKEN=changeme-in-production    # Bearer token for /admin/reload
SHADOW_MODEL_VERSION=                 # optional: e.g. '5' to run shadow deploy
FEATURE_REPO_DIR=feature_repo/
MODEL_NAME=bmo_flight_delay

# Fly.io (set via: fly secrets set KEY=VALUE)
# MLFLOW_TRACKING_URI=http://<oracle-vm-ip>:5000
# REDIS_URL=redis://<upstash-endpoint>:PORT
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_ENDPOINT_URL=https://...r2.cloudflarestorage.com